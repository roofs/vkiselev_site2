---
interface Props {
  url: string; // absolute URL to share
  title?: string;
}
const { url, title } = Astro.props as Props;
const enc = encodeURIComponent;
const fb = `https://www.facebook.com/sharer/sharer.php?u=${enc(url)}`;
const vk = `https://vk.com/share.php?url=${enc(url)}`;
const tw = `https://twitter.com/intent/tweet?url=${enc(url)}${title ? `&text=${enc(title)}` : ''}`;
---
<div class="social-center pull-right">
  <div class="social-likes">
    <div class="share" style="padding-left: 6px">Share:</div>
    <!-- Используем структуру, совместимую с нашими fallback-стилями в global.css -->
    <a href={fb} target="_blank" rel="noopener noreferrer" class="facebook"><div class="social-likes__icon"></div></a>
    <a href={vk} target="_blank" rel="noopener noreferrer" class="vkontakte"><div class="social-likes__icon"></div></a>
    <a href={tw} target="_blank" rel="noopener noreferrer" class="twitter"><div class="social-likes__icon"></div></a>
  </div>
</div>
<br />
<div class="clear-fix"></div>
