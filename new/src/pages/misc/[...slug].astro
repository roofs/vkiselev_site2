---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from 'astro:content';
import { Image } from "astro:assets";
import VideoEmbed from "../../components/VideoEmbed.astro";
import AnimatedHeader from "../../components/AnimatedHeader.astro";
import NextPrev from "../../components/NextPrev.astro";
import SocialShare from "../../components/SocialShare.astro";
import FollowBlock from "../../components/FollowBlock.astro";

export async function getStaticPaths() {
  const collection = 'misc';
  const reverse = true;
  const entries = await getCollection(collection);
  const byId = new Map(entries.map((e) => [String(parseInt(e.id, 10)), e] as const));

  return entries.map((entry) => {
    const idNum = parseInt(entry.id, 10);
    const slug = entry.data.url || String(idNum);
    const prevId = String(idNum - 1);
    const nextId = String(idNum + 1);

    let prev: any = undefined;
    let next: any = undefined;

    if (byId.has(prevId)) {
      const pe = byId.get(prevId)!;
      prev = { url: `/${collection}/${pe.data.url || String(parseInt(pe.id, 10))}` , name: pe.data.hover_text };
    }
    if (byId.has(nextId)) {
      const ne = byId.get(nextId)!;
      next = { url: `/${collection}/${ne.data.url || String(parseInt(ne.id, 10))}` , name: ne.data.hover_text };
    }

    if (reverse) {
      const t = prev; prev = next; next = t;
    }

    return {
      params: { slug },
      props: { entry, prev, next, path: `/${collection}/${slug}` },
    };
  });
}

const { entry, prev, next, path } = Astro.props as { entry: any, prev?: {url: string, name: string}, next?: {url: string, name: string}, path: string };
const fullUrl = new URL(path, Astro.site!).toString();
const { Content } = await entry.render();
---
<Layout 
  title={entry.data.hover_text} 
  description={entry.data.hover_text}
  image={entry.data.thumbnail?.src}
  twitter={entry.data.twitter}
  facebook={entry.data.facebook}
  the_book={entry.data.the_book}
  showGlobalHeader={false}
>
  <AnimatedHeader />
  <NextPrev prev={prev} next={next} />
  <div class="padding-top-big"></div>
  <article class="row">
    <div class="col-md-7">
      {entry.data.youtube && <VideoEmbed url={entry.data.youtube} width={entry.data.width} height={entry.data.height} />}
      {!entry.data.youtube && entry.data.full && (
        <Image 
          src={entry.data.full} 
          alt={entry.data.hover_text} 
          width={600} 
          widths={[400, 800, 1200]}
          sizes="(max-width: 767px) 100vw, 600px"
        />
      )}
    </div>
    <div class="col-md-5 cartoon_item-text">
      <Content />
      <div class="share-block">
        <SocialShare url={fullUrl} title={entry.data.hover_text} />
        <FollowBlock twitter={entry.data.twitter} facebook={entry.data.facebook} the_book={entry.data.the_book} />
      </div>
    </div>
  </article>
</Layout>
