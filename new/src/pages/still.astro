---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import StillHeader from "../components/StillHeader.astro";
import UpButton from "../components/UpButton.astro";
import SocialShare from "../components/SocialShare.astro";

const flat = (await getCollection("flat")).sort((a, b) => parseInt(b.id) - parseInt(a.id));
const projects = (await getCollection("projects")).sort((a, b) => parseInt(b.id) - parseInt(a.id));
const comics = (await getCollection("comics")).sort((a, b) => parseInt(b.id) - parseInt(a.id));
---
<Layout 
  title="Still - vkiselev.com" 
  description="A collection of still stuff by Vasili Kiselev. It includes different paintings. applications, projects and comics. The artist is interested in colour, emotions and relationships between people and with oneself."
  image="/static/img/fb_still.jpg"
  showGlobalHeader={false}
>
  <StillHeader />
  <div class="padding-top-big"></div>
  <div id="flat" class="still_section">flat</div>
  <div class="row">
    {flat.map((e) => (
      <div class="col-md-3 col-sm-4 col-landscape cartoon_item">
        <a class="shade-hover" href={`/flat/${e.data.url || String(parseInt(e.id, 10))}`}>
          {e.data.thumbnail && <Image src={e.data.thumbnail} alt={e.data.hover_text} width={250} />}
          <div class="still_desc">{e.data.hover_text}</div>
        </a>
      </div>
    ))}
  </div>

  <div id="projects" class="still_section">projects</div>
  <div class="row">
    {projects.map((e) => (
      <div class="col-md-3 col-sm-4 col-landscape cartoon_item">
        <a class="shade-hover" href={`/projects/${e.data.url || String(parseInt(e.id, 10))}`}>
          {e.data.thumbnail && <Image src={e.data.thumbnail} alt={e.data.hover_text} width={250} />}
          <div class="still_desc">{e.data.hover_text}</div>
        </a>
      </div>
    ))}
  </div>

  <div id="comics" class="still_section">comics and series</div>
  <div class="row">
    {comics.map((e) => (
      <div class="col-md-3 col-sm-4 col-landscape cartoon_item">
        <a class="shade-hover" href={`/comics/${e.data.url || String(parseInt(e.id, 10))}`}>
          {e.data.thumbnail && <Image src={e.data.thumbnail} alt={e.data.hover_text} width={250} />}
          <div class="still_desc">{e.data.hover_text}</div>
        </a>
      </div>
    ))}
  </div>

  <UpButton />
  {(() => { const fullUrl = new URL('/still', Astro.site!).toString(); return <SocialShare url={fullUrl} title="Still Graphics" /> })()}
</Layout>
