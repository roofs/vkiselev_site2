---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from 'astro:content';
import VideoEmbed from "../../components/VideoEmbed.astro";
import AnimatedHeader from "../../components/AnimatedHeader.astro";
import NextPrev from "../../components/NextPrev.astro";
import SocialShare from "../../components/SocialShare.astro";
import FollowBlock from "../../components/FollowBlock.astro";

function buildLink(e: any, collection: string) {
  return `/${collection}/${e.data.url || e.id}`;
}

export async function getStaticPaths() {
  const collection = 'cartoons';
  const reverse = true; // как в старом коде
  const entries = await getCollection(collection);
  const byId = new Map(entries.map((e) => [e.id, e] as const));

  return entries.map((entry) => {
    const slug = entry.data.url || entry.id;
    const id = parseInt(entry.id, 10);
    const prevId = String(id - 1);
    const nextId = String(id + 1);

    let prev: any = undefined;
    let next: any = undefined;

    if (byId.has(prevId)) {
      const pe = byId.get(prevId)!;
      prev = { url: buildLink(pe, collection), name: pe.data.hover_text };
    }
    if (byId.has(nextId)) {
      const ne = byId.get(nextId)!;
      next = { url: buildLink(ne, collection), name: ne.data.hover_text };
    }

    // Совпасть с поведением get_next_prev(reverse=True): вернуть (next, prev)
    if (reverse) {
      const t = prev; prev = next; next = t;
    }

    return {
      params: { slug: entry.data.url || entry.id },
      props: { entry, prev, next, path: `/${collection}/${slug}` },
    };
  });
}

const { entry, prev, next, path } = Astro.props as { entry: any, prev?: {url: string, name: string}, next?: {url: string, name: string}, path: string };
const fullUrl = new URL(path, Astro.site!).toString();
const { Content } = await entry.render();
---
<Layout 
  title={entry.data.hover_text} 
  description={entry.data.hover_text}
  image={entry.data.thumbnail?.src}
  twitter={entry.data.twitter}
  facebook={entry.data.facebook}
  the_book={entry.data.the_book}
  showGlobalHeader={false}
>
  <AnimatedHeader />
  <div class="padding-top-big"></div>
  <NextPrev prev={prev} next={next} />
  <article>
    {entry.data.youtube && <VideoEmbed url={entry.data.youtube} width={entry.data.width} height={entry.data.height} />}
    <Content />

    <SocialShare url={fullUrl} title={entry.data.hover_text} />
    <FollowBlock twitter={entry.data.twitter} facebook={entry.data.facebook} the_book={entry.data.the_book} />
  </article>
</Layout>
