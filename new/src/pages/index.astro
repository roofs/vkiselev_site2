---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import animBigImg from "../assets/img/anim_big.jpg";
import stillBigImg from "../assets/img/still_big.jpg";
import memBigImg from "../assets/img/mem_big.jpg";
import vkBigImg from "../assets/img/vk_big.jpg";

const cartoons = await getCollection("cartoons");
const flat = await getCollection("flat");
const princess = await getCollection("princess");
const projects = await getCollection("projects");

function getRandom(arr: any[]) {
  return arr[Math.floor(Math.random() * arr.length)];
}

const pitems = [
  getRandom(cartoons),
  getRandom(flat),
  getRandom([...princess, ...(await getCollection("misc"))]),
  getRandom([...projects, ...(await getCollection("comics"))])
].filter(Boolean);
---
<Layout title="vkiselev.com" image="/static/img/fb_base.jpg" showGlobalHeader={false} containerClass="container-fluid">
    <div class="row index-row">
      <div class="col-md-6 break-index" style="padding: 0 !important;">
        <div class="row">
          <nobr><a href="/animated"><img src={animBigImg.src} alt="animated" class="index_image shade-hover" /></a><a href="/still"><img src={stillBigImg.src} alt="still" class="index_image shade-hover" /></a></nobr>
        </div>
        <div class="row">
          <nobr><a href="/memories"><img src={memBigImg.src} alt="memories" class="index_image shade-hover" /></a><a href="/vasili"><img src={vkBigImg.src} alt="vasili" class="index_image shade-hover" /></a></nobr>
        </div>
      </div>

      <div class="col-md-4"></div>

      <div class="col-md-2">
        {pitems.map((e) => (
          <div class="row">
            <div class="cartoon_item">
              <a class="shade-hover" href={`/${e.collection}/${e.data.url || String(parseInt(e.id, 10))}`}>
                {e.data.thumbnail && <Image src={e.data.thumbnail} alt={e.data.hover_text} width={150} height={112} />}
                <div class="cartoon_desc">{e.data.hover_text}</div>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
</Layout>
