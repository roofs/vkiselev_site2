---
import "../styles/global.css";
import { Image } from "astro:assets";
import animSmImg from "../assets/img/anim_sm.png";
import stillSmImg from "../assets/img/still_sm.png";
import memSmImg from "../assets/img/mem_sm.png";
import vkSmImg from "../assets/img/vk_sm.png";

interface Props {
  title: string;
  description?: string;
  image?: string;
  twitter?: string;
  facebook?: string;
  the_book?: string;
  showGlobalHeader?: boolean;
}
const { title, description, image, twitter, facebook, the_book, showGlobalHeader = true } = Astro.props as Props & { showGlobalHeader?: boolean };
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    {image && <meta property="og:image" content={image} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {image && <meta name="twitter:image" content={image} />}
    <link href="https://netdna.bootstrapcdn.com/bootstrap/3.3.4/css/bootstrap.min.css" rel="stylesheet" />
  </head>
  <body>
    {showGlobalHeader && (
      <header>
        <div class="row global-header">
          <span class="header-rest pull-right">
            <a href="/animated"><Image class="shade-hover" src={animSmImg} alt="Animated" width={40} /></a>
            <a href="/still"><Image class="shade-hover" src={stillSmImg} alt="Still" width={40} /></a>
            <a href="/memories"><Image class="shade-hover" src={memSmImg} alt="Memories" width={40} /></a>
            <a href="/vasili"><Image class="shade-hover" src={vkSmImg} alt="Vasili" width={40} /></a>
          </span>
        </div>
      </header>
    )}
    <main class="container">
      <slot />
      
      {(twitter || facebook || the_book) && (
        <div class="share social-likes-topm">
          {twitter && <a href={twitter} class="ext_ref" target="_blank">Twitter</a>}
          {facebook && <a href={facebook} class="ext_ref" target="_blank">Facebook</a>}
          {the_book && <a href={the_book} class="ext_ref" target="_blank">The Book</a>}
        </div>
      )}
    </main>
    <footer>
      <div class="container text-center">
        <p>© vkiselev.com</p>
      </div>
    </footer>
  </body>
</html>
